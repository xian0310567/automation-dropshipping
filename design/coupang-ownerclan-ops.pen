        },
        {
          "type": "text",
          "id": "hDzNL",
          "x": 64,
          "y": 184,
          "name": "briefDesc",
          "fill": "#64748B",
          "textGrowth": "fixed-width",
          "width": 1080,
          "content": "쿠팡 판매 상태, 오너클랜 재고와 공급가, 발주·송장·CS·반품 위험을 한글 업무 언어로 정리한 운영 워크스페이스입니다.",
          "lineHeight": 1.5,
          "fontFamily": "$font-ui",
          "fontSize": 14,
          "fontWeight": "normal"
        },
        {
