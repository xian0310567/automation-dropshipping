          "fill": "#64748B",
          "textGrowth": "fixed-width",
          "width": 584,
          "content": "내부 실행 단계와 API 안전장치 이름은 화면 밖으로 내리고, 운영자는 결과와 필요한 조치만 봅니다.",
          "lineHeight": 1.5,
          "fontFamily": "$font-ui",
          "fontSize": 13,
